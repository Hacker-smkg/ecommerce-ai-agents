# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# E-commerce Platform APIs
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_SECRET_KEY=your_shopify_secret_key
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token
SHOPIFY_SHOP_URL=your-shop.myshopify.com

# Analytics APIs
GOOGLE_ANALYTICS_CREDENTIALS_PATH=path/to/google-analytics-credentials.json
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ecommerce_ai
MONGODB_URL=mongodb://localhost:27017/ecommerce_ai

# Agent Configuration
AGENT_MODEL=gpt-4-turbo-preview
TEMPERATURE=0.7
MAX_TOKENS=2000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ecommerce_ai.log
