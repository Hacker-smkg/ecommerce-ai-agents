# App settings
APP_NAME=E-commerce AI Agents API
APP_VERSION=2.0.0
APP_DESCRIPTION=Backend API for a modular multi-agent e-commerce orchestration system.
HOST=0.0.0.0
PORT=8000
RELOAD=false
LOG_LEVEL=INFO

# Security
# If REQUIRE_API_KEY=true, all non-health endpoints require X-API-Key.
API_KEY=change-me
REQUIRE_API_KEY=false

# Database
DATABASE_URL=sqlite:///./data/ecommerce_ai.db

# Optional integration placeholders
OPENAI_API_KEY=your_openai_api_key_here
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_SECRET_KEY=your_shopify_secret_key
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token
SHOPIFY_SHOP_URL=your-shop.myshopify.com
GOOGLE_ANALYTICS_CREDENTIALS_PATH=path/to/google-analytics-credentials.json
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_APP_SECRET=your_facebook_app_secret
